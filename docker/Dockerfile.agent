FROM python:3.12-slim AS builder

WORKDIR /app

COPY docker/requirements-agent.txt /app/requirements-agent.txt

RUN python -m venv /app/.venv \
    && /app/.venv/bin/pip install --no-cache-dir --upgrade pip \
    && /app/.venv/bin/pip install --no-cache-dir -r /app/requirements-agent.txt

FROM python:3.12-slim

WORKDIR /app

COPY --from=builder /app/.venv /app/.venv

ENV PATH="/app/.venv/bin:$PATH"
ENV PYTHONUNBUFFERED=1

COPY src /app/src
COPY assets /app/assets

RUN python -m src.core.agents.session download-files

CMD ["python", "-m", "src.core.agents.session", "start"]
